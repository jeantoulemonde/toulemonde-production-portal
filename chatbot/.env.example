# ============================================================
# Module chatbot — variables d'environnement (POC, retirable)
# ============================================================
# Recopiez les 6 premières lignes dans backend/.env
# et la dernière dans frontend/.env pour activer le module.

# Activation côté backend (true / false)
CHATBOT_ENABLED=false

# === LLM local Ollama ===
# Hôte Ollama (par défaut localhost:11434). En prod sur le VPS, garder 127.0.0.1.
OLLAMA_HOST=http://127.0.0.1:11434

# Modèle de génération (français natif, Apache 2.0)
OLLAMA_GENERATION_MODEL=mistral:7b-instruct-v0.3-q4_K_M

# Modèle d'embeddings (768 dimensions)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Timeout par appel Ollama en millisecondes (génération peut prendre 8-15s)
OLLAMA_TIMEOUT_MS=60000

# Limite anti-abus : nombre maximum de messages par client par heure
CHATBOT_RATE_LIMIT_PER_HOUR=30

# Activation côté frontend (true / false). À mettre dans frontend/.env
# (pas backend/.env), Vite ne lit que les variables préfixées VITE_*.
VITE_CHATBOT_ENABLED=false
