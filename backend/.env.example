# ============================================================
# Backend portail Toulemonde Production — variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
#
#   cp backend/.env.example backend/.env
#
# Le fichier .env est gitignored. NE LE COMMITEZ JAMAIS.

# ------------------------------------------------------------
# Postgres — base de données du portail
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=toulemonde_portal
POSTGRES_USER=
POSTGRES_PASSWORD=
# Mettre "true" si la connexion Postgres exige TLS (prod cloud).
POSTGRES_SSL=false

# ------------------------------------------------------------
# Authentification — JWT et clés
# ------------------------------------------------------------
# IMPORTANT : générer des secrets longs et aléatoires en prod.
#   openssl rand -hex 64
JWT_SECRET=
REFRESH_SECRET=

# Clé partagée entre le portail et leon-agent.
AGENT_API_KEY=

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------
PORT=3010
NODE_ENV=development
